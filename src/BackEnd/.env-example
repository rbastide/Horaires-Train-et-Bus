API_SNCF_KEY=<TOKEN donné par la SNCF>
SNCF_URL=<URL de l'api SNCF>
COVERAGE=<Coverage de l'API SNCF>
PORT=<Port de votre backend>
API_BASE=<URL publique de votre backend sans le port>
STOP_AREA=<Numéro de la gare de votre choix>

DB_HOST=<Url de votre BDD>
DB_USER=<Utilisateur de votre BDD>
DB_PORT=<Port de votre BDD>
DB_PASSWORD=<Mot de passe de votre BDD>
DATABASE=<Nom de votre BDD>